rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function isAuthenticated() {
      return request.auth != null;
    }

    function userRole() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role;
    }

    function userExamClass() {
      return firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.examClass;
    }

    match /photos/{examClass}/{uploaderId}/{fileName} {
      allow read: if isAuthenticated() && userExamClass() == examClass;
      allow write: if isAuthenticated() && (userRole() == 'mentor' || userRole() == 'photographer');
    }
  }
}
